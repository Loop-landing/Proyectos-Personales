<!DOCTYPE html>
<html>
<head>
<title>Registro</title>
<link rel="stylesheet" href="/css/style.css">
</head>
<body>

<div class="background"></div>
<div class="auth-container">
<a href="/" class="logo" style="display: block; margin-bottom: 20px; text-decoration: none; color: inherit; text-align: center; font-weight: bold; font-size: 1.5rem;">MI WEB PRO</a>

<h1>Crear cuenta</h1>

<form method="POST" action="/register">

<input type="text" name="name" placeholder="Nombre completo" required>

<input type="text" name="company" placeholder="Empresa o marca">

<input type="text" name="whatsapp" placeholder="WhatsApp">

<select name="projectType">
<option>Landing Page</option>
<option>Pagina Web</option>
<option>Tienda Online</option>
<option>SaaS</option>
<option>Automatizacion</option>
</select>

<input type="email" name="email" placeholder="Correo electrónico" required>

<input type="password" name="password" placeholder="Contraseña" required>

<button type="submit">
Crear cuenta
</button>

</form>

</div>

</body>
</html>
