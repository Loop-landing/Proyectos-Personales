<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Login — Mi Web Pro</title>
<link rel="stylesheet" href="/css/style.css">
</head>
<body>
<canvas id="bg-canvas"></canvas>

<div class="auth-container">

  <a href="/" style="display:flex;align-items:center;gap:10px;text-decoration:none;color:inherit;margin-bottom:32px;">
    <span class="logo-mark">GB</span>
    <span style="font-size:0.95rem;font-weight:700;">Mi Web Pro</span>
  </a>

  <h1>Bienvenido</h1>
  <p style="color:var(--text-2);font-size:0.88rem;margin-top:6px;margin-bottom:8px;">Ingresa a tu panel</p>

  <% if (typeof error !== 'undefined' && error) { %>
    <div style="background:rgba(248,113,113,0.08);border:1px solid rgba(248,113,113,0.2);padding:12px 14px;border-radius:var(--radius-sm);margin:16px 0;color:var(--error);font-size:0.85rem;">
      <%= error %>
    </div>
  <% } %>

  <form method="POST" action="/login">
    <input type="email"    name="email"    placeholder="Correo electrónico" required>
    <input type="password" name="password" placeholder="Contraseña"         required>
    <button type="submit">Ingresar</button>
  </form>

  <p style="margin-top:20px;text-align:center;font-size:0.84rem;color:var(--text-3);">
    ¿Sin cuenta?
    <a href="/register" style="color:var(--text-2);text-decoration:none;font-weight:500;"> Regístrate →</a>
  </p>
</div>

<script src="/js/particles.js"></script>
</body>
</html>
