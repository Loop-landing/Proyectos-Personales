<!DOCTYPE html>
<html lang="es">
<head>
    <title>Soporte - Tickets</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="background"></div>
    <div class="container">
        <nav>
            <a href="/" class="logo">MI WEB PRO</a>
            <div class="nav-actions">
                <a href="/dashboard" class="nav-btn" data-tooltip="Volver al dashboard">Panel</a>
                <a href="/perfil" class="nav-btn" data-tooltip="Edita tu información">Mi perfil</a>
                <a href="/logout" class="nav-btn" data-tooltip="Cerrar sesión">Salir</a>
            </div>
        </nav>

        <h1 style="margin: 40px 0;">Centro de <span>Soporte</span></h1>

        <div class="grid">
            <div class="card">
                <h3>Abrir Nuevo Ticket</h3>
                <form action="/tickets" method="POST">
                    <input type="text" name="subject" placeholder="Asunto del problema" required>
                    <textarea name="message" placeholder="Describe tu solicitud..." style="width:100%; height:100px; background:#111827; border:none; border-radius:12px; padding:15px; color:white; margin-top:15px;"></textarea>
                    <button type="submit">Enviar Ticket</button>
                </form>
            </div>

            <div class="card">
                <h3>Mis Tickets</h3>
                <ul style="list-style: none; margin-top: 20px;">
                    <% tickets.forEach(ticket => { %>
                    <li style="padding: 15px; background: rgba(0,0,0,0.2); border-radius: 10px; margin-bottom: 10px;">
                        <div style="display: flex; justify-content: space-between;">
                            <strong><%= ticket.id %></strong>
                            <span style="color: #00ffd5; font-size: 12px;"><%= ticket.status %></span>
                        </div>
                        <p style="font-size: 14px; margin-top: 5px;"><%= ticket.subject %></p>
                        <% if (ticket.message) { %>
                            <p style="font-size: 13px; color: #aaa; margin: 8px 0;"><%= ticket.message %></p>
                        <% } %>
                        <% if (ticket.adminResponse) { %>
                            <div style="margin: 10px 0; padding: 10px; background: rgba(0, 255, 213, 0.1); border-left: 3px solid #00ffd5; border-radius: 5px;">
                                <small style="color: #00ffd5; display: block; margin-bottom: 5px; font-weight: bold;">Soporte Mi Web Pro:</small>
                                <p style="font-size: 13px;"><%= ticket.adminResponse %></p>
                            </div>
                        <% } %>
                        <small style="color: #555;"><%= ticket.date %></small>
                    </li>
                    <% }); %>
                </ul>
            </div>
        </div>
    </div>
</body>
</html>