<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Mi Web Pro</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="dashboard-body">
    <canvas id="bg-canvas"></canvas>
    <nav>
        <a href="/" class="logo" style="text-decoration:none;color:inherit;">MI WEB PRO</a>
        <div class="nav-actions">
            <span style="color:#888;font-size:0.88rem;padding:0 4px;">Hola, <%= user.name %></span>
            <a href="/perfil" class="nav-btn" data-tooltip="Edita tu información">Mi perfil</a>
            <% if (notifCount > 0) { %>
                <a href="/tickets" class="nav-btn" data-tooltip="<%= notifCount %> respuesta(s) nueva(s)" style="position:relative;">
                    Soporte <span class="notif-badge"><%= notifCount %></span>
                </a>
            <% } else { %>
                <a href="/tickets" class="nav-btn" data-tooltip="Centro de soporte">Soporte</a>
            <% } %>
            <% if (user.role === 'admin') { %>
                <a href="/admin" class="nav-btn nav-btn--primary" data-tooltip="Panel de administración">Admin</a>
            <% } %>
            <a href="/logout" class="nav-btn" data-tooltip="Cerrar sesión">Salir</a>
        </div>
    </nav>

    <div class="container">
        <% if (newResponses && newResponses.length > 0) { %>
            <div class="notification-banner">
                <div class="notification-icon">🔔</div>
                <div class="notification-text">
                    <strong>¡Tienes una respuesta!</strong> Soporte respondió a <%= newResponses.length %> de tus tickets.
                </div>
                <a href="/tickets" class="primary-btn" style="margin:0;padding:8px 16px;font-size:0.85rem;">Ver respuesta</a>
            </div>
        <% } %>

        <h1 style="margin:40px 0 30px;">Panel de Control</h1>
        <div class="grid">
            <a href="/portafolio" class="card-link">
                <div class="card">
                    <h3>Mis Proyectos</h3>
                    <p>Estado del desarrollo:</p>
                    <div class="progress-container">
                        <div class="progress-bar <%= isDelayed ? 'delayed' : '' %>" data-progress="<%= projectProgress %>"></div>
                    </div>
                    <p class="<%= isDelayed ? 'delayed-text' : 'completed-text' %>" style="font-size:12px;margin-top:8px;">
                        <%= projectProgress %>% <%= isDelayed ? 'Retrasado' : 'Completado' %>
                    </p>
                </div>
            </a>

            <a href="/tickets" class="card-link">
                <div class="card">
                    <h3>Soporte <% if (notifCount > 0) { %><span class="notif-badge" style="position:static;display:inline-flex;vertical-align:middle;margin-left:6px;"><%= notifCount %></span><% } %></h3>
                    <p>Tienes <strong><%= ticketCount %></strong> tickets activos.</p>
                </div>
            </a>

            <a href="/perfil" class="card-link">
                <div class="card">
                    <h3>Mi Perfil</h3>
                    <p>Actualiza tu nombre, empresa, WhatsApp y contraseña.</p>
                </div>
            </a>

            <a href="/mis-archivos" class="card-link">
                <div class="card">
                    <h3>📂 Mis Archivos</h3>
                    <p>Descargá los entregables y documentos de tu proyecto.</p>
                </div>
            </a>

            <% if (user.role === 'admin') { %>
                <a href="/admin" class="card-link">
                    <div class="card" style="border:1px solid #00ffd5;background:rgba(0,255,213,0.05);">
                        <h3>Panel Admin</h3>
                        <p>Gestión global de usuarios, clientes y tickets.</p>
                    </div>
                </a>
            <% } %>
        </div>
    </div>

    <script>
        document.querySelectorAll('.progress-bar[data-progress]').forEach(el => {
            el.style.width = `${Number(el.dataset.progress) || 0}%`;
        });
    </script>
    <script src="/js/particles.js"></script>
</body>
</html>
